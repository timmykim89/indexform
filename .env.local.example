# Sanity project configuration.
# Copy this file to `.env.local` and fill in the values from https://www.sanity.io/manage
#
# The site runs WITHOUT these values — Offer/Archive content falls back to the
# built-in design defaults. Set them to enable the Sanity Studio at /studio and
# bind live CMS content.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
